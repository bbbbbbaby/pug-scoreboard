{
  "routes": [
    {
      "src": "/sw\\.js",
      "dest": "/sw.js",
      "headers": {
        "Content-Type": "application/javascript; charset=utf-8",
        "Cache-Control": "no-cache",
        "Service-Worker-Allowed": "/"
      }
    },
    {
      "src": "/manifest\\.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/avatars/(.*)",
      "dest": "/avatars/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/icon-(.*)\\.png",
      "dest": "/icon-$1.png"
    },
    {
      "src": "/splash-(.*)\\.png",
      "dest": "/splash-$1.png"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}